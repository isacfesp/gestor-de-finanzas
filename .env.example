# Plantilla de variables de entorno. Copiar a .env en la raíz del repo y
# rellenar con valores reales — .env está en .gitignore, nunca se commitea.
#
# Para producción (Easypanel) estas mismas claves se configuran en el
# panel de cada servicio, no se sube este archivo con datos reales.

# Configuración para la Base de Datos
DB_USER=usuario
DB_PASSWORD=
DB_NAME=gestor

# Configuración para la App de Axum
PORT=3000

# SQLx — se construye desde las variables de arriba
DATABASE_URL=postgres://${DB_USER}:${DB_PASSWORD}@localhost:5432/${DB_NAME}

# Autenticación — JWT y usuario dev inicial (bootstrap, solo se usa si
# no existe todavía ningún usuario con rol dev)
JWT_SECRET=
DEV_EMAIL=
DEV_PASSWORD=

# Orígenes permitidos por CORS para llamadas desde el navegador, separados
# por comas. En dev cae por defecto a los puertos de trunk serve. También
# se usa el primero de la lista para armar los links de los correos
# (invitaciones, recuperación de contraseña).
FRONTEND_ORIGIN=http://localhost:8080,http://127.0.0.1:8080

# Correo transaccional (invitaciones, recuperación de contraseña, alertas
# de reminders) vía la API de Resend: https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM=
