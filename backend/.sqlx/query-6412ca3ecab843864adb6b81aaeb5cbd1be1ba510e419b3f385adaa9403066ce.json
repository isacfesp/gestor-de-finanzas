{
  "db_name": "PostgreSQL",
  "query": "SELECT a.id, COALESCE(u.name, 'Sistema') AS \"actor_name!\",\n                  a.action, a.detail, a.created_at\n           FROM audit_log a\n           LEFT JOIN users u ON u.id = a.user_id\n           WHERE a.workspace_id = $1\n           ORDER BY a.created_at DESC\n           LIMIT $2 OFFSET $3",
