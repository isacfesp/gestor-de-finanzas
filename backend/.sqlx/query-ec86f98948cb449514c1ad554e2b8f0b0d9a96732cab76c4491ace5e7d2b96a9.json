  "query": "SELECT id, workspace_id, owner_id, category_id, month, limit_amount\n           FROM budgets\n           WHERE workspace_id = $1\n             AND ($2::date IS NULL OR month = $2)\n             AND ($3::uuid IS NULL OR owner_id = $3)\n           ORDER BY month DESC, category_id",
