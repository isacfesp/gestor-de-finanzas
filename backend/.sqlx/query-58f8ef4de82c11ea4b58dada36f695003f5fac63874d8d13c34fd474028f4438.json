  "query": "UPDATE goals\n           SET name = $1, target_amount = $2, deadline = $3,\n               is_completed = (current_amount >= $2)\n           WHERE id = $4 AND workspace_id = $5\n           RETURNING id, workspace_id, name, target_amount, current_amount,\n                     deadline, is_completed, created_at",
